{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Sentinel SAST: Scan Current File",
            "type": "shell",
            "command": "python",
            "args": [
                "${workspaceFolder}/cli/sast-cli.py",
                "${file}",
                "--format",
                "gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "shared"
            },
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}"
                ],
                "pattern": {
                    "regexp": "^(.*):(\\d+):\\s+(high|medium|low):\\s+\\[(CWE-\\d+)\\]\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "severity": 3,
                    "code": 4,
                    "message": 5
                }
            }
        }
    ]
}
